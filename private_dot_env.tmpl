# Secrets managed by chezmoi + Proton Pass.
#
# To add a new secret:
#   1. pass-cli item create login --vault-name "Personal" --title "My Secret" --password "value"
#      → prints the item ID
#   2. Add a line below using the vault and item IDs:
#      export MY_VAR="{{ "{{" }} protonPass "pass://VAULT_ID/ITEM_ID/password" | trim {{ "}}" }}"
#   3. chezmoi apply
